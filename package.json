{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "test": "vitest",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "analyze": "nuxt analyze",
    "postinstall": "simple-git-hooks && nuxt prepare"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.7.1",
    "@nuxt/icon": "^1.4.5",
    "@nuxt/image": "^1.7.0",
    "@pinia/nuxt": "^0.5.2",
    "nuxt": "^3.12.4",
    "pinia": "^2.2.0",
    "radix-vue": "^1.9.2",
    "vue": "latest"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.5.0",
    "@nuxt/test-utils": "^3.14.0",
    "@nuxtjs/device": "^3.1.1",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^14.12.3",
    "lint-staged": "^15.2.8",
    "playwright-core": "^1.46.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "simple-git-hooks": "^2.11.1",
    "vitest": "^2.0.5",
    "zx": "^8.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec zx scripts/verify-commit.mjs"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,jsx,tsx,vue}": [
      "eslint",
      "prettier --write"
    ],
    "*.{css,less,scss,json,md}": [
      "prettier --write"
    ]
  }
}
